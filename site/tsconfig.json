{
  "compilerOptions": {
    "moduleResolution": "Node",
    "lib": ["ES2023", "DOM"],
    "target": "ES2021",
    "jsx": "react-jsx",
    "strict": true,
    "downlevelIteration": true,
    "noUncheckedIndexedAccess": true,
    "allowSyntheticDefaultImports": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": ["node_modules/", "dist/"]
}
